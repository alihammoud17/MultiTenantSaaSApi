# Copy this file to /etc/multitenant-saas-api/api.env before running Docker.
# Change every placeholder value before local runtime.
# This file configures the ASP.NET Core API container.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# .NET connection strings/settings use double-underscore format.
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=saasapi;Username=saasapi_user;Password=CHANGE_ME_DB_PASSWORD
Redis__ConnectionString=redis:6379,password=CHANGE_ME_REDIS_PASSWORD

# JWT settings (MUST be replaced with strong values).
Jwt__Secret=CHANGE_ME_WITH_A_LONG_RANDOM_256_BIT_SECRET
Jwt__Issuer=MultiTenantSaasApi
Jwt__Audience=MultiTenantSaasApi
Jwt__ExpirationMinutes=60

# Internal signed callback integration with BillingService.
BillingIntegration__SharedSecret=CHANGE_ME_INTERNAL_BILLING_SHARED_SECRET
BillingIntegration__AllowedClockSkewMinutes=5

# Optional container metadata
SERVICE_NAME=api
