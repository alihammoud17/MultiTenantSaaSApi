# Copy this file to /etc/multitenant-saas-api/billing.env before running Docker.
# Change every placeholder value before local runtime.
# This file configures BillingService.

NODE_ENV=development
PORT=3001
SERVICE_NAME=billing
BILLING_PROVIDER=placeholder

# Provider webhook signing placeholder (future provider verification path).
WEBHOOK_SIGNING_SECRET=CHANGE_ME_PROVIDER_WEBHOOK_SECRET

# Internal callback target for BillingService -> .NET API.
DOTNET_CALLBACK_BASE_URL=http://api:8080

# Keep this identical to BillingIntegration__SharedSecret in api.env.
INTERNAL_BILLING_SHARED_SECRET=CHANGE_ME_INTERNAL_BILLING_SHARED_SECRET

# Stripe placeholders (required only when BILLING_PROVIDER=stripe).
STRIPE_API_KEY=CHANGE_ME_STRIPE_API_KEY
STRIPE_API_BASE_URL=https://api.stripe.com

# Durable workflow placeholders.
WORKFLOW_STATE_PATH=/var/lib/billing/.billing-workflow-state.json
WORKFLOW_MAX_ATTEMPTS=3
WORKFLOW_INITIAL_BACKOFF_MS=1000
WORKFLOW_MAX_BACKOFF_MS=30000
WORKFLOW_POLL_INTERVAL_MS=2000
RECONCILIATION_INTERVAL_MS=300000
